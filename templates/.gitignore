# Derived from the source project's .gitignore, with product-specific entries (demo vaults,
# generated fixtures, planning docs, the vault index) pruned.

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies and build output
node_modules
dist
dist-ssr
site/.vitepress/cache/
site/.vitepress/dist/
_site/
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Playwright
/test-results/
/playwright-report/

# Coverage reports
/coverage/

# Claude Code task signals
.claude-done
.claude-blocked
.claude-pid

# Claude Code writes the adopter's own approvals here — personal, never committed.
# (This profile pre-approves the CodeScene MCP via `claude_settings` in profile.json, which
# the engine merges into the tracked .claude/settings.json instead.)
.claude/settings.local.json

# Rust / Tauri build artifacts
src-tauri/target

# Python cache
__pycache__/
*.py[cod]

# Tauri signing keys (never commit private keys)
*.key
*.key.pub

# Local environment variables (never commit)
.env
.env.local
.env.*.local

# Local Codacy CLI runtime/config generated by the MCP server
.codacy/
